          "editorType": "sql",
          "format": 0,
          "queryType": "timeseries",
          "rawSql": "SELECT\n    toDateTime(event_date) AS time,\n    countIf(event_type = 'VIEW_FINISHED') / nullIf(countIf(event_type = 'VIEW_STARTED'), 0) AS conversion\nFROM analytics.movie_events_raw\nWHERE $__timeFilter(event_time)\nGROUP BY event_date\nORDER BY event_date",
          "refId": "A"
