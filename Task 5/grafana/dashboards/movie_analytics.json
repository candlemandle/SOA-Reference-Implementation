  "panels": [
    {
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds"},
      "description": "Retention Cohort Heatmap. По вертикали — когорты пользователей по дате первого просмотра. По горизонтали — день жизни (Day 0..Day 7). В ячейках — % пользователей, вернувшихся в соответствующий день.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center",
            "cellOptions": {"type": "color-background", "mode": "gradient"},
            "inspect": false,
            "minWidth": 60
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "dark-red", "value": null},
              {"color": "red", "value": 10},
              {"color": "orange", "value": 25},
              {"color": "yellow", "value": 40},
              {"color": "green", "value": 60}
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "cohort_date"},
            "properties": [
              {"id": "custom.cellOptions", "value": {"type": "color-text"}},
              {"id": "custom.minWidth", "value": 110},
              {"id": "unit", "value": "string"}
            ]
          }
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds"},
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH\n    first_day AS (\n        SELECT\n            user_id,\n            toDate(min(event_time)) AS cohort_date\n        FROM analytics.movie_events_raw\n        GROUP BY user_id\n    ),\n    activity AS (\n        SELECT\n            f.cohort_date AS cohort_date,\n            e.user_id AS user_id,\n            dateDiff('day', f.cohort_date, e.event_date) AS day_offset\n        FROM analytics.movie_events_raw AS e\n        INNER JOIN first_day AS f USING (user_id)\n        WHERE dateDiff('day', f.cohort_date, e.event_date) BETWEEN 0 AND 7\n        GROUP BY cohort_date, user_id, day_offset\n    ),\n    cohort_size AS (\n        SELECT cohort_date, count() AS total\n        FROM first_day\n        GROUP BY cohort_date\n    )\n    SELECT\n        toString(a.cohort_date) AS cohort_date,\n        round(100 * countIf(a.day_offset = 0) / any(cs.total), 0) AS \"Day 0\",\n        round(100 * countIf(a.day_offset = 1) / any(cs.total), 0) AS \"Day 1\",\n        round(100 * countIf(a.day_offset = 2) / any(cs.total), 0) AS \"Day 2\",\n        round(100 * countIf(a.day_offset = 3) / any(cs.total), 0) AS \"Day 3\",\n        round(100 * countIf(a.day_offset = 4) / any(cs.total), 0) AS \"Day 4\",\n        round(100 * countIf(a.day_offset = 5) / any(cs.total), 0) AS \"Day 5\",\n        round(100 * countIf(a.day_offset = 6) / any(cs.total), 0) AS \"Day 6\",\n        round(100 * countIf(a.day_offset = 7) / any(cs.total), 0) AS \"Day 7\"\n    FROM activity AS a\n    INNER JOIN cohort_size AS cs USING (cohort_date)\n    GROUP BY a.cohort_date\n    ORDER BY a.cohort_date DESC\n    LIMIT 30",
          "refId": "A"
        }
      ],
      "title": "Retention Cohort Heatmap",
      "type": "table"
    },
    {
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds"},
      "description": "Daily Active Users — уникальные пользователи за день (uniqMerge над агрегатом dau_agg).",
      "fieldConfig": {
